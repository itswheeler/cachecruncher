{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cache-calc",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "cachecruncher.com", "custom_domain": true },
    { "pattern": "www.cachecruncher.com", "custom_domain": true }
  ]
}
